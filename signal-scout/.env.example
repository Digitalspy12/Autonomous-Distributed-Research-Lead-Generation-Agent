# === Signal Scout 4.0 — Environment Variables ===

# Google AI Studio (Gemini 2.5 Flash)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true

# Groq Cloud (Free Tier — console.groq.com)
GROQ_API_KEY=
GROQ_MODEL_ANALYST=llama-3.1-70b-versatile
GROQ_MODEL_STRATEGIST=llama-3.1-8b-instant
GROQ_ENABLED=true

# Enrichment APIs
HUNTER_API_KEY=
APOLLO_API_KEY=

# Supabase (Cloud Database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ANALYST=qwen3.5:latest
OLLAMA_MODEL_CRITIC=qwen3.5:latest
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT_SECONDS=120

# Local Database
SQLITE_PATH=./data/signal_scout.db

# Rate Limits
SCOUT_INTERVAL_HOURS=4
GEMINI_DAILY_QUOTA=20
HUNTER_MONTHLY_QUOTA=25
APOLLO_MONTHLY_QUOTA=50
SEARXNG_DAILY_QUOTA=20

# LLM Fallback Behavior
LLM_FALLBACK_ORDER=gemini,groq,ollama
SKIP_ON_NO_LLM=true
